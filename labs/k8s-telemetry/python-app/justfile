# =========================================================================
# build → push → rollout for the lab pyapp (reference pipeline)
# =========================================================================
# k3s + the local registry (127.0.0.1:5000) are provided by omni-nix.
# k3s is on-demand — start it first:  sudo systemctl start k3s
# =========================================================================
set shell := ["bash", "-c"]

image := "localhost:5000/pyapp"
tag   := "latest"
ns    := "lab"
dep   := "pyapp"

# Build the Nix image (no Dockerfile, no docker).
build:
    nix build .#image --out-link result

# Push to the local registry over HTTP (no docker).
push: build
    #!/usr/bin/env bash
    set -euo pipefail
    skopeo copy --insecure-policy --dest-tls-verify=false \
      docker-archive:"$(readlink -f result)" \
      docker://"{{image}}:{{tag}}"

# Apply the lab manifest + roll the Deployment so k3s pulls the new image.
deploy: push
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl apply -f ../manifests/70-pyapp.yaml
    kubectl -n {{ns}} rollout restart deployment/{{dep}}
    kubectl -n {{ns}} rollout status   deployment/{{dep}}

logs:
    kubectl -n {{ns}} logs deploy/{{dep}} -f

forward:
    kubectl -n {{ns}} port-forward svc/{{dep}} 8080:8080

shell:
    nix develop
