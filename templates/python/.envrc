# =========================================================================
# direnv — auto-loads the flake devShell on cd
# =========================================================================
# Requires direnv + nix-direnv (omni-nix → home/devshell.nix). After editing
# flake.nix OR this file:  direnv allow
use flake

# Auto-activate the project venv once it exists. Create it once:
#     uv venv && uv pip install -r app/requirements.txt
if [ -f .venv/bin/activate ]; then
  source .venv/bin/activate
fi
