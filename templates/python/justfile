# =========================================================================
# build → push → deploy  (works for BOTH variants)
# =========================================================================
# Set `variant` to match flake.nix. Requires omni-nix's k3s cluster + the
# local registry (127.0.0.1:5000) running. `just`/`skopeo` are in the devShell
# (and globally on omni-nix hosts).
# =========================================================================
set shell := ["bash", "-c"]

variant := "fastapi"   # "fastapi" (web service) | "script" (Kubernetes Job)
image   := "localhost:5000/pyapp"
tag     := "latest"
ns      := "default"
dep     := "pyapp"     # Deployment name (fastapi) / Job name (script)

# Build the Nix image (no Dockerfile, no docker).
build:
    nix build .#image --out-link result

# Push to the local registry over HTTP (no docker). `result` resolves to the
# image tarball that dockerTools.buildImage produces.
push: build
    #!/usr/bin/env bash
    set -euo pipefail
    skopeo copy --insecure-policy --dest-tls-verify=false \
      docker-archive:"$(readlink -f result)" \
      docker://"{{image}}:{{tag}}"

# Apply the variant's manifests + (re)run it.
deploy: push
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{variant}}" = "script" ]; then
      # Jobs are immutable — delete first so `apply` re-runs it after edits.
      kubectl -n {{ns}} delete job {{dep}} --ignore-not-found
    fi
    kubectl apply -f manifests/{{variant}}/
    if [ "{{variant}}" = "fastapi" ]; then
      kubectl -n {{ns}} rollout restart deployment/{{dep}}
      kubectl -n {{ns}} rollout status   deployment/{{dep}}
    else
      echo "Job '{{dep}}' submitted. Watch:  kubectl -n {{ns}} get job {{dep}} -w"
    fi

# Run locally (uvicorn for fastapi, python for script) — needs `uv venv` first.
run:
    #!/usr/bin/env bash
    cd app
    if [ "{{variant}}" = "script" ]; then
      uv run python script.py
    else
      uv run uvicorn main:app --reload --port 8080
    fi

# Tail logs (Deployment for fastapi, Job pod for script).
logs:
    #!/usr/bin/env bash
    if [ "{{variant}}" = "script" ]; then
      kubectl -n {{ns}} logs job/{{dep}} -f
    else
      kubectl -n {{ns}} logs deploy/{{dep}} -f
    fi

# Port-forward the Service (fastapi only — scripts have no Service).
forward:
    #!/usr/bin/env bash
    [ "{{variant}}" = "fastapi" ] || { echo "forward is for the fastapi variant (scripts ship no Service)"; exit 1; }
    kubectl -n {{ns}} port-forward svc/{{dep}} 8080:8080

# Drop into the devShell manually (direnv does this automatically on cd).
shell:
    nix develop
