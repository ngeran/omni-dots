# =========================================================================
# build → push → rollout for the python service
# =========================================================================
# Requires omni-nix's k3s cluster + local registry (127.0.0.1:5000) running.
# `just` and `skopeo` are in this project's devShell (and globally on
# omni-nix hosts via modules/apps/dev-tools.nix).
#
# Edit the vars below for your image / namespace / Deployment name.
# Recipes with a `#!/usr/bin/env bash` shebang run as ONE script (so
# `set -euo pipefail` + `\`-continuations hold); one-liners don't need it.
# =========================================================================
set shell := ["bash", "-c"]

image := "localhost:5000/pyapp"
tag   := "latest"
ns    := "default"        # change to match an existing Namespace
dep   := "pyapp"

# Build the Nix image (no Dockerfile, no docker).
build:
    nix build .#image --out-link result

# Push to the local registry over HTTP (no docker). The `result` symlink
# resolves to the image tarball that dockerTools.buildImage produces.
push: build
    #!/usr/bin/env bash
    set -euo pipefail
    skopeo copy --insecure-policy --dest-tls-verify=false \
      docker-archive:"$(readlink -f result)" \
      docker://"{{image}}:{{tag}}"

# Apply manifests + roll the Deployment so k3s pulls the new image.
deploy: push
    #!/usr/bin/env bash
    set -euo pipefail
    kubectl apply -f manifests/
    kubectl -n {{ns}} rollout restart deployment/{{dep}}
    kubectl -n {{ns}} rollout status   deployment/{{dep}}

# Tail the pod logs.
logs:
    kubectl -n {{ns}} logs deploy/{{dep}} -f

# Port-forward :8080 → curl localhost:8080 locally.
forward:
    kubectl -n {{ns}} port-forward svc/{{dep}} 8080:8080

# Drop into the devShell manually (direnv does this automatically on cd).
shell:
    nix develop
