# =========================================================================
# build → push → deploy  (works for BOTH variants)
# =========================================================================
# Set `variant` to match flake.nix. Requires omni-nix's k3s cluster + the
# local registry (127.0.0.1:5000) running. `just`/`skopeo` are in the devShell
# (and globally on omni-nix hosts).
# =========================================================================
set shell := ["bash", "-c"]

variant := "fastapi"   # "fastapi" (web service) | "script" (Kubernetes Job)
image   := "localhost:5000/pyapp"
tag     := "latest"
ns      := "default"
dep     := "pyapp"     # Deployment name (fastapi) / Job name (script)
port    := "8080"      # container listen port (fastapi uvicorn)

# Build the Nix image (no Dockerfile, no docker).
build:
    nix build .#image --out-link result

# Push to the local registry over HTTP (no docker). `result` resolves to the
# image tarball that dockerTools.buildImage produces.
push: build
    #!/usr/bin/env bash
    set -euo pipefail
    skopeo copy --insecure-policy --dest-tls-verify=false \
      docker-archive:"$(readlink -f result)" \
      docker://"{{image}}:{{tag}}"

# Apply the variant's manifests + (re)run it.
deploy: push
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{variant}}" = "script" ]; then
      # Jobs are immutable — delete first so `apply` re-runs it after edits.
      kubectl -n {{ns}} delete job {{dep}} --ignore-not-found
    fi
    kubectl apply -f manifests/{{variant}}/
    if [ "{{variant}}" = "fastapi" ]; then
      kubectl -n {{ns}} rollout restart deployment/{{dep}}
      kubectl -n {{ns}} rollout status deployment/{{dep}} --timeout=120s || {
        echo "FAIL rollout - pod status + last crash log:"
        kubectl -n {{ns}} get pods
        kubectl -n {{ns}} logs deployment/{{dep}} --previous --tail=40
        exit 1
      }
    else
      echo "Job '{{dep}}' submitted. Watch:  kubectl -n {{ns}} get job {{dep}} -w"
    fi

# Run locally from the devShell venv (uvicorn for fastapi, python for script).
# The venv is built from pyproject.toml/uv.lock via uv2nix — no `uv pip install`.
run:
    #!/usr/bin/env bash
    cd app
    if [ "{{variant}}" = "script" ]; then
      python script.py
    else
      uvicorn main:app --reload --port 8080
    fi

# Tail logs (Deployment for fastapi, Job pod for script).
logs:
    #!/usr/bin/env bash
    if [ "{{variant}}" = "script" ]; then
      kubectl -n {{ns}} logs job/{{dep}} -f
    else
      kubectl -n {{ns}} logs deploy/{{dep}} -f
    fi

# Port-forward the Service (fastapi only — scripts have no Service).
forward:
    #!/usr/bin/env bash
    [ "{{variant}}" = "fastapi" ] || { echo "forward is for the fastapi variant (scripts ship no Service)"; exit 1; }
    kubectl -n {{ns}} port-forward svc/{{dep}} 8080:8080

# Pre-flight: k3s up, local registry reachable, git index clean (nix evaluates
# the git INDEX, not the worktree, so unstaged edits to flake.nix/app are blind).
doctor:
    #!/usr/bin/env bash
    set -uo pipefail
    ok=1
    systemctl is-active --quiet k3s && echo "  k3s        up" || { echo "  k3s        DOWN -> sudo systemctl start k3s"; ok=0; }
    curl -sf --max-time 3 http://localhost:5000/v2/ >/dev/null && echo "  registry   localhost:5000 reachable" || { echo "  registry   UNREACHABLE -> start k3s / the registry"; ok=0; }
    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      n=$(git status --porcelain . 2>/dev/null | wc -l)
      [ "$n" = 0 ] && echo "  git        clean" || echo "  git        WARN - $n unstaged/untracked here (nix uses the git INDEX: stage with git add or nix build ignores them)"
    else
      echo "  git        (not a worktree - skip)"
    fi
    [ "$ok" = 1 ] && echo "doctor: ready" || { echo "doctor: NOT ready"; exit 1; }

# Local smoke: load the built image into docker, run it, curl /, expect 200.
test: build
    #!/usr/bin/env bash
    set -euo pipefail
    command -v docker >/dev/null || { echo "test needs docker (virtualization.nix)"; exit 1; }
    img=$(docker load < "$(readlink -f result)" | sed -n 's/Loaded image: \(.*\)/\1/p')
    echo "loaded $img"
    docker rm -f {{dep}}-test >/dev/null 2>&1 || true
    docker run -d --name {{dep}}-test --tmpfs /tmp:mode=1777,uid=1000,gid=1000 -p 18080:{{port}} "$img" >/dev/null
    sleep 2
    if curl -sf --max-time 5 http://localhost:18080/ >/dev/null; then
      echo "  HTTP 200 from /  OK"
    else
      echo "  FAIL no 200 - container logs:"; docker logs {{dep}}-test 2>&1 | tail -25; docker rm -f {{dep}}-test >/dev/null; exit 1
    fi
    docker rm -f {{dep}}-test >/dev/null
    echo "test: ok"

# Drop into the devShell manually (direnv does this automatically on cd).
shell:
    nix develop
